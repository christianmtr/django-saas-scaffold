# [[ project_name ]] — Variables de entorno
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitear .env al repositorio.

# Django
SECRET_KEY=cambia-esto-por-un-valor-seguro-de-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,[[ base_domain ]]

# Base de datos
DB_NAME=[[ project_slug ]]_db
DB_NAME_TEST=[[ project_slug ]]_test
DB_USER=postgres
DB_PASSWORD=cambia-esto
DB_HOST=db
DB_PORT=5432

[% if use_celery %]# Redis / Celery
REDIS_URL=redis://redis:6379/0

[% endif %]# Email (dejar vacío en desarrollo — se usa console backend)
EMAIL_HOST=smtp.ejemplo.com
EMAIL_PORT=587
EMAIL_HOST_USER=no-reply@[[ base_domain ]]
EMAIL_HOST_PASSWORD=cambia-esto
DEFAULT_FROM_EMAIL=[[ project_name ]] <no-reply@[[ base_domain ]]>

# CORS — URLs del frontend permitidas en producción (separadas por coma)
CORS_ALLOWED_ORIGINS=https://[[ base_domain ]],https://app.[[ base_domain ]]
